        "## 4 — Train a single model (reusable function)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "Anky9Q1ZwHkH",
        "outputId": "b886aa3d-7f95-4728-fe45-fc63bacd3224"
      },
      "outputs": [
