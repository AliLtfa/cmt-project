      ],
      "source": [
        "# pick the best method\n",
        "results_table = {\n",
        "    'EfficientNet-B0': (acc_e, f1_e, preds_e),\n",
        "    'ResNet-18': (acc_r, f1_r, preds_r),\n",
        "    'Ensemble': (ens_acc, ens_f1, ens_preds.tolist()),\n",
        "    'Ensemble+TTA': (tta_acc, tta_f1, tta_preds.tolist()),\n",
        "}\n",
