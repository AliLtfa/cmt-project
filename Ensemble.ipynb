      "source": [
        "# ===== PATIENT-LEVEL AGGREGATION =====\n",
        "# Instead of predicting per-cycle, aggregate all cycles from each patient\n",
        "# and take the average probability.\n",
        "\n",
        "import numpy as np\n",
        "from sklearn.metrics import classification_report, confusion_matrix, ConfusionMatrixDisplay, f1_score\n",
        "from collections import defaultdict\n",
        "\n",
        "# load test data with patient IDs\n",
        "test_data = np.load(os.path.join(DATA_DIR, 'test_data.npz'))\n",
        "test_patient_ids = test_data['patient_ids']\n",
        "test_true_labels = test_data['disease_labels']\n",
        "\n",
        "# get per-cycle logits from both models (reuse what we already have)\n",
        "model_eff.load_state_dict(torch.load(os.path.join(SAVE_DIR, 'effnet_best.pth'), map_location=device))\n",
        "model_res.load_state_dict(torch.load(os.path.join(SAVE_DIR, 'resnet_best.pth'), map_location=device))\n",
        "\n",
        "logits_e, _ = get_logits(model_eff, test_loader)\n",
        "logits_r, _ = get_logits(model_res, test_loader)\n",
        "ensemble_logits = (logits_e + logits_r) / 2\n",
        "cycle_probs = torch.softmax(ensemble_logits, dim=1).numpy()\n",
        "\n",
        "# group by patient and average probabilities\n",
        "patient_probs = defaultdict(list)\n",
        "patient_true = {}\n",
        "\n",
        "for i, pid in enumerate(test_patient_ids):\n",
        "    patient_probs[pid].append(cycle_probs[i])\n",
        "    patient_true[pid] = test_true_labels[i]  # same for all cycles from this patient\n",
        "\n",
        "# aggregate\n",
        "patient_ids_sorted = sorted(patient_probs.keys())\n",
        "y_true_patient = []\n",
        "y_pred_patient = []\n",
        "y_probs_patient = []\n",
        "\n",
        "print(f\"{'Patient':>8s}  {'True':20s}  {'Predicted':20s}  {'Conf':>6s}  {'Cycles':>6s}  {'Match':>5s}\")\n",
        "print(\"-\" * 75)\n",
        "\n",
        "for pid in patient_ids_sorted:\n",
        "    avg_prob = np.mean(patient_probs[pid], axis=0)\n",
        "    pred_idx = avg_prob.argmax()\n",
        "    true_idx = patient_true[pid]\n",
        "    n_cycles = len(patient_probs[pid])\n",
        "    match = \"✓\" if pred_idx == true_idx else \"✗\"\n",
        "\n",
        "    y_true_patient.append(true_idx)\n",
        "    y_pred_patient.append(pred_idx)\n",
        "    y_probs_patient.append(avg_prob)\n",
        "\n",
        "    print(f\"{pid:>8d}  {IDX_TO_LABEL[true_idx]:20s}  {IDX_TO_LABEL[pred_idx]:20s}  \"\n",
        "          f\"{avg_prob[pred_idx]:5.0%}  {n_cycles:6d}  {match:>5s}\")\n",
        "\n",
        "# compute metrics\n",
        "y_true_patient = np.array(y_true_patient)\n",
        "y_pred_patient = np.array(y_pred_patient)\n",
        "\n",
        "patient_acc = 100 * (y_true_patient == y_pred_patient).mean()\n",
        "patient_f1 = 100 * f1_score(y_true_patient, y_pred_patient, average='macro', zero_division=0)\n",
        "\n",
        "# balanced accuracy = mean of per-class recalls\n",
        "present = sorted(set(y_true_patient))\n",
        "recalls = []\n",
        "for c in present:\n",
        "    mask = y_true_patient == c\n",
        "    if mask.sum() > 0:\n",
        "        recalls.append((y_pred_patient[mask] == c).mean())\n",
        "balanced_acc = 100 * np.mean(recalls)\n",
        "\n",
        "print(f\"\\n{'='*55}\")\n",
        "print(f\"  PATIENT-LEVEL RESULTS ({len(patient_ids_sorted)} patients)\")\n",
        "print(f\"{'='*55}\")\n",
        "print(f\"  Accuracy:          {patient_acc:.1f}%\")\n",
        "print(f\"  Balanced accuracy: {balanced_acc:.1f}%\")\n",
        "print(f\"  Macro F1:          {patient_f1:.1f}%\")\n",
        "print(f\"{'='*55}\")\n",
        "\n",
        "print(f\"\\n  Compare with cycle-level:\")\n",
        "print(f\"  Cycle accuracy:    {ens_acc:.1f}%  →  Patient: {patient_acc:.1f}%\")\n",
        "print(f\"  Cycle F1:          {ens_f1:.1f}%  →  Patient: {patient_f1:.1f}%\")\n",
        "\n",
        "# classification report\n",
        "names = [IDX_TO_LABEL[i] for i in present]\n",
        "print(f\"\\nClassification Report (patient-level):\")\n",
        "print(classification_report(y_true_patient, y_pred_patient,\n",
        "      labels=present, target_names=names, digits=3, zero_division=0))\n",
        "\n",
        "# confusion matrix\n",
        "fig, ax = plt.subplots(figsize=(8, 6))\n",
        "cm = confusion_matrix(y_true_patient, y_pred_patient, labels=present)\n",
        "ConfusionMatrixDisplay(cm, display_labels=names).plot(ax=ax, cmap='Blues', values_format='d')\n",
        "ax.set_title(f'Patient-Level — Acc={patient_acc:.1f}%, Bal.Acc={balanced_acc:.1f}%, F1={patient_f1:.1f}%',\n",
        "             fontweight='bold')\n",
        "plt.xticks(rotation=45, ha='right')\n",
        "plt.tight_layout()\n",
        "plt.savefig(os.path.join(SAVE_DIR, 'patient_level_confusion.png'), dpi=150)\n",
        "plt.show()"
      ]
    },
